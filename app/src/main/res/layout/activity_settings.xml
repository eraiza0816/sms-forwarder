<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".SettingsActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Webhook 設定"
        android:textAppearance="@style/TextAppearance.AppCompat.Title"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edittext_webhook_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Webhook URL"
        android:textColorHint="#888888"
        android:inputType="textUri"/>

    <Button
        android:id="@+id/button_save_webhook"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Webhook URL を保存"
        android:layout_marginTop="8dp"
        android:layout_gravity="end"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ログ管理"
        android:textAppearance="@style/TextAppearance.AppCompat.Title"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/button_refresh_log_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ログを更新"/>
        <Button
            android:id="@+id/button_clear_log_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ログをクリア"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#e0e0e0"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/textview_log_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:typeface="monospace"
            android:textIsSelectable="true"
            android:textColor="#212121"
            tools:text="ログ内容が表示されます..."/>
    </ScrollView>

</LinearLayout>